-- ✅ HITBOX
-- ==============================================
local originalData = {}
local function ResetAllHitboxes()
    for userId, data in pairs(originalData) do
        if data.Character and data.Character:IsDescendantOf(Workspace) then
            pcall(function()
                if data.RootPart then
                    data.RootPart.Size = data.OriginalRootSize
                    data.RootPart.Transparency = data.OriginalRootTransparency
                    data.RootPart.CanCollide = data.OriginalRootCanCollide
                    data.RootPart.Color = Color3.new(0.64, 0.64, 0.64)
                    data.RootPart.Material = Enum.Material.Plastic
                end
                if data.Head then
                    data.Head.Size = data.OriginalHeadSize
                    data.Head.Transparency = data.OriginalHeadTransparency
                    data.Head.CanCollide = data.OriginalHeadCanCollide
                    data.Head.Color = Color3.new(1, 1, 1)
                    data.Head.Material = Enum.Material.Plastic
                end
                if data.Torso then
                    data.Torso.Size = data.OriginalTorsoSize
                    data.Torso.Transparency = data.OriginalTorsoTransparency
                    data.Torso.CanCollide = data.OriginalTorsoCanCollide
                    data.Torso.Color = Color3.new(0.8, 0.6, 0.4)
                    data.Torso.Material = Enum.Material.Plastic
                end
            end)
        end
    end
    table.clear(originalData)
end

RunService.Heartbeat:Connect(function()
    if not Config.EnemyHitbox then ResetAllHitboxes() return end
    local activeIds = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
        if not hum or not root or hum.Health <= 0 then continue end
        activeIds[plr.UserId] = true
        if not originalData[plr.UserId] then
            originalData[plr.UserId] = {
                Character = char, RootPart = root, OriginalRootSize = root.Size,
                OriginalRootTransparency = root.Transparency, OriginalRootCanCollide = root.CanCollide,
                Head = head, OriginalHeadSize = head and head.Size or Vector3.new(1,1,1),
                OriginalHeadTransparency = head and head.Transparency or 0, OriginalHeadCanCollide = head and head.CanCollide or true,
                Torso = torso, OriginalTorsoSize = torso and torso.Size or Vector3.new(2,2,1),
                OriginalTorsoTransparency = torso and torso.Transparency or 0, OriginalTorsoCanCollide = torso and torso.CanCollide or true
            }
        end
        pcall(function()
            if root then
                root.Size = Config.HitboxSize
                root.Transparency = math.min(Config.HitboxTransparency, 0.9)
                root.CanCollide = false
                root.Color = Config.BoxColor
                root.Material = Enum.Material.Neon
            end
            if head then
                head.Size = Vector3.new(Config.HitboxSize.X * 0.8, Config.HitboxSize.Y * 0.8, Config.HitboxSize.Z * 0.8)
                head.Transparency = math.min(Config.HitboxTransparency, 0.9)
                head.CanCollide = false
                head.Color = Config.BoxColor
                head.Material = Enum.Material.Neon
            end
            if torso then
                torso.Size = Vector3.new(Config.HitboxSize.X, Config.HitboxSize.Y * 0.9, Config.HitboxSize.Z)
                torso.Transparency = math.min(Config.HitboxTransparency, 0.9)
                torso.CanCollide = false
                torso.Color = Config.BoxColor
                torso.Material = Enum.Material.Neon
            end
        end)
    end
    for userId in pairs(originalData) do
        if not activeIds[userId] then ResetAllHitboxes() originalData[userId] = nil end
    end
end)

