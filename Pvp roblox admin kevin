-- ==============================================
-- ✅ SPEED + VELOCITY
-- ==============================================
RunService.Heartbeat:Connect(function(dt)
    if not Humanoid or not RootPart or Humanoid.Health <= 0 then return end

    if Config.SpeedEnabled then
        speedActive = true
        local targetSpeed = math.min(Config.WalkSpeed, Config.MaxSafeSpeed)
        pcall(function()
            if Humanoid.WalkSpeed ~= targetSpeed then Humanoid.WalkSpeed = targetSpeed end
            if Humanoid.JumpPower ~= Config.JumpPower then Humanoid.JumpPower = Config.JumpPower end
            if Humanoid.MoveDirection.Magnitude > 0.1 then
                local boost = Humanoid.MoveDirection * Config.VelocityBoost
                RootPart.Velocity = Vector3.new(
                    math.clamp(RootPart.Velocity.X + boost.X, -targetSpeed * 1.4, targetSpeed * 1.4),
                    RootPart.Velocity.Y,
                    math.clamp(RootPart.Velocity.Z + boost.Z, -targetSpeed * 1.4, targetSpeed * 1.4)
                )
            end
            if Config.AntiKick and (RootPart.Position - Camera.CFrame.Position).Magnitude > 25000 then
                RootPart.CFrame = CFrame.new(Camera.CFrame.Position + Vector3.new(0, 10, 0))
            end
        end)
    else
        if not speedActive then return end
        pcall(function()
            Humanoid.WalkSpeed = originalWalkSpeed
            Humanoid.JumpPower = originalJumpPower
            RootPart.Velocity = Vector3.new(0, RootPart.Velocity.Y, 0)
        end)
        speedActive = false
    end
end)

-- ==============================================
-- ✅ AIM
-- ==============================================
local function GetAimPartAndOffset(character)
    if not character then return nil, Vector3.new(0,0,0) end
    local part, offset = nil, Vector3.new(0,0,0)
    if Config.AimMode == "Head" then
        part = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
        offset = Vector3.new(0, 0.4, 0)
    elseif Config.AimMode == "Body" then
        part = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
        offset = Vector3.new(0, 0.1, 0)
    elseif Config.AimMode == "Foot" then
        part = character:FindFirstChild("RightFoot") or character:FindFirstChild("LeftFoot") or character:FindFirstChild("HumanoidRootPart")
        offset = Vector3.new(0, -0.3, 0)
    elseif Config.AimMode == "GlassHead" then
        part = character:FindFirstChild("Glasses") or character:FindFirstChild("RedGlasses") or character:FindFirstChild("HeadAccessory") or character:FindFirstChild("Head")
        offset = Vector3.new(0, 0.6, 0)
    elseif Config.AimMode == "GlassBody" then
        part = character:FindFirstChild("RedHitbox") or character:FindFirstChild("BodyHitbox") or character:FindFirstChild("HumanoidRootPart")
        offset = Vector3.new(0, 0.25, 0)
    elseif Config.AimMode == "GlassFoot" then
        part = character:FindFirstChild("RedFoot") or character:FindFirstChild("FootHitbox") or character:FindFirstChild("RightFoot") or character:FindFirstChild("LeftFoot")
        offset = Vector3.new(0, -0.15, 0)
    end
    return part, offset
end

local function GetTarget()
    local bestTarget, bestOffset, bestDist = nil, Vector3.new(0,0,0), math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        local part, offset = GetAimPartAndOffset(char)
        if not hum or not part or hum.Health <= 0 then continue end
        local dist = (RootPart.Position - part.Position).Magnitude
        if dist > Config.AimRange then continue end
        local ray = Ray.new(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * Config.AimRange)
        local hit = Workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
        if not hit or not hit:IsDescendantOf(char) then continue end
        if dist < bestDist then
            bestDist = dist
            bestTarget = part
            bestOffset = offset
        end
    end
    return bestTarget, bestOffset
end

RunService.RenderStepped:Connect(function(dt)
    if not Config.AimEnabled or not RootPart then return end
    local target, offset = GetTarget()
    if target then
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position + offset), Config.AimSmooth * 10 * dt)
    end
end)

UserInputService.InputBegan:Connect(function(i)
    if i.KeyCode == Config.AimKey then
        Config.AimEnabled = not Config.AimEnabled
    end
end)

-- ==============================================
-- ✅ AUTO HỒI MÁU
-- ==============================================
local lastHealTime = 0
local healAttempts = 0

RunService.Heartbeat:Connect(function()
    if not Config.AutoHeal or not Humanoid or Humanoid.Health <= 0 or not Character then return end
    local currentHP = Humanoid.Health
    local maxHP = Humanoid.MaxHealth
    if currentHP >= maxHP or currentHP > (maxHP * Config.HealThreshold / 100) then
        healAttempts = 0
        return
    end
    if os.clock() - lastHealTime < Config.HealDelay then return end
    local canHeal = true
    if Config.CheckHealItem then
        local tool = Character:FindFirstChildOfClass("Tool")
        if not tool then canHeal = false
        else
            local name = tool.Name:lower()
            canHeal = false
            for _,w in ipairs(Config.HealItemNames) do if name:find(w) then canHeal = true break end end
        end
    end
    if not canHeal then return end
    lastHealTime = os.clock()
    healAttempts += 1
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Config.HealKey, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, Config.HealKey, false, game)
        local eq = Character:FindFirstChildOfClass("Tool")
        if eq then eq:Activate() if eq:FindFirstChild("RemoteEvent") then eq.RemoteEvent:FireServer() end end
    end)
    if healAttempts > 5 then lastHealTime = os.clock() + 3 healAttempts = 0 end
end)

